  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"react,go\" -c \"blue,green\" \"npm run dev:react\" \"npm run dev:go\"",
    "dev:react": "vite",
    "dev:go": "ts-node ./go-sqlite-server/start-server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
