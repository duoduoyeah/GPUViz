    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/styled-components": "^5.1.34",
    "better-sqlite3": "^12.2.0",
